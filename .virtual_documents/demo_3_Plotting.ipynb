from PyVisualFields import visualFields

df_VFs_py = visualFields.data_vfpwgRetest24d2() #df_VFs_py is acquired using vfpwgRetest24d2() function. 
vf = df_VFs_py.iloc[[0]] #lets pick the first VF of df_VFs_py as example

visualFields.vfplot(vf, type='s', title='Sensitivity', save=True, filename='file', fmt='png') # types: s, td,pd, tds, pds
visualFields.vfplot_s(vf, title='Sensitivity', save=True, filename='file', fmt='png') # types: s, td,pd, tds, pds
visualFields.vfplot_td(vf, title='Total Deviaton and Probability', save=True, filename='td', fmt='png') # alias for vfplot(type='td')
visualFields.vfplot_pd(vf, title='Pattern Deviaton and Probability', save=True, filename='pd', fmt='pdf') # alias for vfplot(type='pd')
visualFields.vfplot_tds(vf, title='Sensitivity, Total Deviaton and its Probability', save=True, filename='tds', fmt='png') # alias for vfplot(type='tds')
visualFields.vfplot_pds(vf, title='Sensitivity, Pattern Deviaton and its Probability', save=True, filename='pds', fmt='png') # alias for vfplot(type='pds')

visualFields.plotProbColormap(save=True, filename='cmap', fmt='png') # show colormap of probablies (from visualFields package)





